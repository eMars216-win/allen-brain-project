import duckdb
import pandas as pd
from pathlib import Path

DONOR_DIR = Path(r"C:\Users\emars\Downloads\normalized_microarray_donor12876")
DB_PATH   = "allen_lateralisation.duckdb"

con = duckdb.connect(DB_PATH)

print("Loading SampleAnnot...")
samples = pd.read_csv(DONOR_DIR / "SampleAnnot.csv")
samples.insert(0, "donor_id", "H0351.2001")
samples.insert(0, "sample_idx", range(len(samples)))
con.execute("DROP TABLE IF EXISTS dim_sample")
con.execute("CREATE TABLE dim_sample AS SELECT * FROM samples")
print(f"  {len(samples)} samples loaded")

print("Loading Probes...")
probes = pd.read_csv(DONOR_DIR / "Probes.csv")
con.execute("DROP TABLE IF EXISTS dim_probe")
con.execute("CREATE TABLE dim_probe AS SELECT * FROM probes")
print(f"  {len(probes)} probes across {probes['gene_symbol'].nunique()} genes")

print("Loading MicroarrayExpression (may take a moment)...")
expr_wide = pd.read_csv(DONOR_DIR / "MicroarrayExpression.csv", header=None)
print(f"  Shape: {expr_wide.shape}")

expr_wide.columns = ["probe_id"] + list(range(len(samples)))

print("Melting to long format...")
expr_long = expr_wide.melt(
    id_vars=["probe_id"],
    var_name="sample_idx",
    value_name="expression"
)
expr_long["sample_idx"] = expr_long["sample_idx"].astype(int)
expr_long["probe_id"]   = expr_long["probe_id"].astype(int)
print(f"  {len(expr_long):,} rows")

print("Writing expression to DuckDB...")
con.execute("DROP TABLE IF EXISTS fact_expression_raw")
con.execute("CREATE TABLE fact_expression_raw AS SELECT * FROM expr_long")
print("  Raw expression written")

print("Joining in DuckDB...")
con.execute("DROP TABLE IF EXISTS fact_expression")
con.execute("""
    CREATE TABLE fact_expression AS
    SELECT
        e.probe_id,
        e.sample_idx,
        e.expression,
        p.gene_symbol,
        p.gene_name,
        p.entrez_id,
        p.chromosome,
        s.donor_id,
        s.structure_id,
        s.structure_name,
        s.structure_acronym,
        s.mni_x,
        s.mni_y,
        s.mni_z
    FROM fact_expression_raw e
    JOIN dim_probe  p ON e.probe_id   = p.probe_id
    JOIN dim_sample s ON e.sample_idx = s.sample_idx
""")

n = con.execute("SELECT COUNT(*) FROM fact_expression").fetchone()[0]
print(f"  Rows written: {n:,}")

con.execute("DROP TABLE IF EXISTS fact_expression_raw")

print("\nSample output:")
print(con.execute("""
    SELECT gene_symbol, structure_name,
           ROUND(expression, 4) AS expression,
           mni_x, mni_y, mni_z
    FROM fact_expression
    WHERE gene_symbol = 'BDNF'
    LIMIT 5
""").fetchdf().to_string(index=False))

con.close()
print("\nDone.")
